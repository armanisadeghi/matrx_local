# Matrx Local — Environment Configuration
# Copy this file to .env and fill in values.

# ---------- Local Engine Auth ----------
# API key that clients must send to use this engine's REST/WS API.
# For local dev, any value works. In production, set a strong random key.
API_KEY=local-dev

# ---------- Remote Scraper Server ----------
# API key for the dedicated scraper server (scraper.app.matrxserver.com).
# Used when delegating scrape jobs to the remote server instead of local engine.
SCRAPER_API_KEY=
SCRAPER_SERVER_URL=https://scraper.app.matrxserver.com

# ---------- Supabase ----------
# Required for document sync and AI operations (matrx-ai client mode).
# Same project as the desktop app's VITE_SUPABASE_URL / VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY.
# These are PUBLISHABLE values — safe to embed in the binary.
# RLS policies on the Supabase project enforce per-user data isolation.
SUPABASE_URL=https://db.matrxserver.com
SUPABASE_PUBLISHABLE_KEY=

# ---------- matrx-ai DB Mode ----------
# matrx-local ALWAYS runs in client mode.
# Uses SUPABASE_URL + SUPABASE_PUBLISHABLE_KEY above — no direct DB credentials needed.
# RLS policies ensure each user can only access their own data.
MATRX_AI_CLIENT_MODE=true

# ---------- matrx-ai Auth ----------
# JWT secret from your Supabase project (Settings → API → JWT Secret).
# Used to validate user tokens on AI endpoints.
SUPABASE_MATRIX_JWT_SECRET=

# ---------- /extension/* JWT validation ----------
# The engine runs on the user's own machine and CANNOT have a server-side
# JWT signing secret. There is no SUPABASE_JWT_SECRET env var — if your
# old .env still has one, you can delete it. See `app/api/extension_auth.py`.
#
# Two posture options:
#   1. JWKS verification (RS256/ES256 only) — derived from SUPABASE_URL
#      above. Works automatically when SUPABASE_URL is set AND the
#      Supabase project has been migrated to asymmetric signing.
#   2. Loopback presence-only (the desktop default) — when JWKS isn't
#      configured OR the token is HS256, the engine accepts any non-empty
#      Bearer over loopback. The trust boundary is the loopback socket,
#      not the JWT signature.

# Optional: admin token for internal/server-to-server AI calls (no JWT needed).
ADMIN_USER_ID=
ADMIN_API_TOKEN=

# ---------- AI Provider Keys ----------
# Add the keys for whichever AI providers you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
CEREBRAS_API_KEY=
XAI_API_KEY=

# ---------- Brave Search (Optional) ----------
# Enables the Search and Research tools.
# Get one at https://brave.com/search/api/
BRAVE_API_KEY=

# ---------- Proxies (Optional) ----------
# Comma-separated proxy URLs for the scraper engine to rotate through.
DATACENTER_PROXIES=
RESIDENTIAL_PROXIES=

# ---------- Cloudflare Tunnel (Remote Access, Optional) ----------
# Default: quick tunnel — cloudflared spawns a subprocess and Cloudflare assigns
# a unique random *.trycloudflare.com URL per session. No token or account needed.
# Set TUNNEL_ENABLED=True to start the tunnel automatically on engine startup.
# Set CLOUDFLARE_TUNNEL_TOKEN for a named tunnel with a stable URL (optional).
TUNNEL_ENABLED=False
# CLOUDFLARE_TUNNEL_TOKEN=

# ---------- Server ----------
# Force a specific port. Default 22140, auto-scans 22140-22159.
# MATRX_PORT=22140

# Debug mode (True/False)
DEBUG=True

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG
