# Matrx Local — Environment Configuration
# Copy this file to .env and fill in values.

# ---------- Local Engine Auth ----------
# API key that clients must send to use this engine's REST/WS API.
# For local dev, any value works. In production, set a strong random key.
API_KEY=local-dev

# ---------- Remote Scraper Server ----------
# API key for the dedicated scraper server (scraper.app.matrxserver.com).
# Used when delegating scrape jobs to the remote server instead of local engine.
SCRAPER_API_KEY=
SCRAPER_SERVER_URL=https://scraper.app.matrxserver.com

# ---------- Supabase ----------
# Required for document sync and for matrx-ai client mode (see below).
# Same project as the desktop app's VITE_SUPABASE_URL / VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY.
# The publishable/anon key is safe to include here — it is designed for client-side use.
# RLS policies on the Supabase project enforce per-user data isolation.
SUPABASE_URL=https://txzxabzwovsujtloxrus.supabase.co
SUPABASE_PUBLISHABLE_KEY=

# ---------- matrx-ai DB Mode ----------
# Controls how matrx-ai connects to the shared database.
#
# OPTION A — Client mode (recommended for matrx-local / desktop deployment):
#   matrx-ai uses the Supabase PostgREST API (anon key + user JWT + RLS).
#   No direct DB credentials stored on the user's machine.
#   Conversations are NOT persisted server-side (AI calls still work fully).
#
# OPTION B — Server mode (for running matrx-local as an internal server):
#   Set MATRX_AI_CLIENT_MODE=false and provide SUPABASE_MATRIX_* vars below.
#   Requires a direct database connection (transaction pooler).
#   Full conversation persistence via the cx_ tables.
#
# Default for matrx-local is client mode (true). Change to false for server mode.
MATRX_AI_CLIENT_MODE=true
# SUPABASE_MATRIX_HOST=
# SUPABASE_MATRIX_PORT=6543
# SUPABASE_MATRIX_DATABASE_NAME=postgres
# SUPABASE_MATRIX_USER=
# SUPABASE_MATRIX_PASSWORD=

# Documents base directory (default: ~/.matrx/documents)
# DOCUMENTS_BASE_DIR=~/.matrx/documents

# ---------- Database (Optional — LOCAL only) ----------
# PostgreSQL connection string for a LOCAL database on the user's machine.
# This is used by the local scraper engine for persistent cache of scraped pages.
# It does NOT connect to the remote scraper server's database — that DB is internal-only.
# Without this, the local scraper engine uses in-memory caching only (works fine for dev).
# DATABASE_URL=postgresql://user:pass@localhost:5432/scraper_cache
DATABASE_URL=

# ---------- Brave Search (Optional) ----------
# Enables the Search and Research tools.
# Get one at https://brave.com/search/api/
BRAVE_API_KEY=

# ---------- Proxies (Optional) ----------
# Comma-separated proxy URLs for the scraper engine to rotate through.
DATACENTER_PROXIES=
RESIDENTIAL_PROXIES=

# ---------- Server ----------
# Force a specific port. Default 22140, auto-scans 22140-22159.
# MATRX_PORT=22140

# Debug mode (True/False)
DEBUG=True

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG
