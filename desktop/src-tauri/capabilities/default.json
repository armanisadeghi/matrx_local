{
  "identifier": "default",
  "description": "Default permissions for AI Matrx Desktop",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" },
        { "url": "x-apple.systempreferences:**" },
        { "url": "mailto:**" }
      ]
    },
    "notification:default",
    "store:default",
    "autostart:default",
    "updater:default",
    "process:allow-restart",
    "deep-link:default",
    "deep-link:allow-get-current",
    "deep-link:allow-register",
    "macos-permissions:default"
  ]
}